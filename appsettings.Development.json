{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CheckoutService.Infrastructure.Messaging": "Debug"
    }
  },
  "MockData": {
    "Enabled": false
  },
  "Services": {
    "ShippingPromise": "https://localhost:7135"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "checkout-service",
    "Topics": {
      "ShippingQuoteRequested": "checkout.shipping.quote.requested",
      "ShippingPromiseCalculated": "shipping.promise.calculated"
    }
  }
}
